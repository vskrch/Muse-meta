# Meta AI Cookie Authentication
# Get these from your browser after logging into https://www.meta.ai/
# DevTools > Application > Cookies > https://www.meta.ai
META_AI_DATR=your_datr_cookie
META_AI_ECTO_1_SESS=your_ecto_1_sess_cookie

# Optional: improves compatibility in some regions
META_AI_ABRA_SESS=your_abra_sess_cookie

# Optional: extracted OAuth token (auto-detected if not set)
META_AI_ACCESS_TOKEN=your_ecto1_token

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Request settings
REQUEST_TIMEOUT=60.0
