# Runtime mode: development, test, or production
ENVIRONMENT=development
DEBUG=false
DOCS_ENABLED=false

# Inbound API protection for /v1/*
# Use Authorization: Bearer <API_KEY> from OpenAI-compatible clients.
REQUIRE_API_KEY=true
API_KEY=change-this-long-random-token
# API_KEYS=token-one,token-two

# Network boundary
HOST=0.0.0.0
PORT=8000
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
# CORS is disabled unless origins are listed.
# CORS_ALLOW_ORIGINS=https://app.example.com
CORS_ALLOW_CREDENTIALS=false

# Abuse and resource limits
MAX_REQUEST_BYTES=1048576
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
REQUEST_TIMEOUT=60.0

# Local state for generated cookies/browser profiles.
STATE_DIR=.state
# COOKIE_FILE=.state/meta_ai_cookies.json

# Meta AI upstream authentication.
# Get these from a browser session you are authorized to use.
META_AI_DATR=your_datr_cookie
META_AI_ECTO_1_SESS=your_ecto_1_sess_cookie
META_AI_ABRA_SESS=your_abra_sess_cookie

# Optional: extracted OAuth token (auto-detected if not set).
META_AI_ACCESS_TOKEN=your_ecto1_token

# Optional: override GraphQL persisted query doc_ids.
# Capture from DevTools > Network when sending a message on meta.ai.
# META_AI_CHAT_DOC_ID=your_primary_doc_id
# META_AI_CHAT_DOC_ID_ALT=your_fallback_doc_id
